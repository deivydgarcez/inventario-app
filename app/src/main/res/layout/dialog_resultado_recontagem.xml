<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/tvTituloResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:text="Resultado da Recontagem"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMensagemResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.3" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22000000"
        android:layout_marginBottom="12dp" />

    <!-- Botão principal: sempre visível quando a recontagem tem resultado -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConsolidarAgora"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:text="Consolidar agora"
        android:textStyle="bold"
        android:elevation="4dp"
        app:backgroundTint="#FF1565C0"
        app:cornerRadius="10dp"
        android:visibility="gone" />

    <!-- Mostrado quando há divergências -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAplicar2a"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:text="Aplicar 2ª contagem (voltar)"
        android:textStyle="bold"
        android:elevation="4dp"
        app:backgroundTint="#FF388E3C"
        app:cornerRadius="10dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnManter1a"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:text="Manter 1ª contagem"
        app:cornerRadius="10dp"
        android:visibility="gone" />

    <!-- Mostrado quando não há divergências -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVoltarRelatorio"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:text="Voltar ao Relatório"
        app:cornerRadius="10dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinuarRecontando"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:text="Continuar recontando"
        app:cornerRadius="10dp" />

</LinearLayout>
