<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screenBackground"
    android:fitsSystemWindows="true">

    <!-- Toolbar com botão voltar (altura dinâmica para acomodar a status bar) -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <!-- Barra de resumo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/cardBackground"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 itens bipados"
            android:textSize="14sp"
            android:textColor="@color/textSecondary"
            android:gravity="center_vertical" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Dica de interação — discreta, aparece só quando há itens -->
    <TextView
        android:id="@+id/tvDicaSwipe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← Deslize item para excluir   ·   Toque para editar"
        android:textSize="11sp"
        android:textColor="@color/textSecondary"
        android:gravity="center"
        android:paddingVertical="4dp"
        android:visibility="gone" />

    <!-- Lista de itens -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- Aviso de produtos não contados (risco de omissão intencional) -->
    <TextView
        android:id="@+id/tvAvisoNaoContados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="6dp"
        android:background="#FFB71C1C"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="12sp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:visibility="gone" />

    <!-- Aviso de bloqueio de consolidação -->
    <TextView
        android:id="@+id/tvAvisoBloqueio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:background="#FFFF8F00"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="12sp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="⚠ Recontagem com divergências. Refaça a recontagem para habilitar consolidar."
        android:visibility="gone"
        />

    <!-- Botões de histórico e auditoria -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistorico"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Histórico"
            android:textSize="12sp"
            app:icon="@drawable/ic_history"
            app:iconSize="14dp"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAuditoria"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Auditoria"
            android:textSize="12sp"
            app:icon="@drawable/ic_report"
            app:iconSize="14dp"
            app:cornerRadius="8dp" />

    </LinearLayout>

    <!-- Botão Recontagem (recomendado quando há divergências) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRecontagem"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="6dp"
        android:text="✓ Fazer Recontagem (Recomendado)"
        android:textSize="14sp"
        android:textStyle="bold"
        android:enabled="false"
        app:cornerRadius="10dp"
        app:backgroundTint="#FF388E3C" />

    <!-- Botão consolidar fixo no rodapé -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConsolidar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="64dp"
        android:text="Consolidar Inventário"
        android:textSize="17sp"
        android:textStyle="bold"
        android:elevation="6dp"
        android:enabled="false"
        app:cornerRadius="10dp"
        app:backgroundTint="#FFCC5B2A" />

</LinearLayout>
